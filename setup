#!/usr/bin/env bash
# tldraw-claude — Setup script
#
# Installs dependencies and registers the plugin with Claude Code.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WIDGET_DIR="$SCRIPT_DIR/widget"

info() { echo "  → $1"; }
success() { echo "  ✓ $1"; }
warn() { echo "  ⚠ $1"; }
error() { echo "  ✗ $1" >&2; }

BUN_CMD="${BUN_INSTALL:+$BUN_INSTALL/bin/bun}"
BUN_CMD="${BUN_CMD:-bun}"

if ! "$BUN_CMD" --version &>/dev/null 2>&1; then
	error "Bun is required. Install from https://bun.sh"
	exit 1
fi

success "Bun found: $("$BUN_CMD" --version)"

# Install widget deps
info "Installing widget dependencies..."
(cd "$WIDGET_DIR" && "$BUN_CMD" install)
success "Widget dependencies installed"

# Register plugin with Claude Code
register_plugin() {
	if ! command -v claude &>/dev/null; then
		warn "Claude Code CLI not found — skipping plugin registration."
		warn "Register manually later with:"
		warn "  claude plugin marketplace add $SCRIPT_DIR --scope user"
		warn "  claude plugin install tldraw-claude@sociotechnica --scope user"
		return 0
	fi

	info "Registering plugin with Claude Code..."

	if ! claude plugin marketplace add "$SCRIPT_DIR" --scope user 2>/dev/null; then
		warn "Marketplace registration failed — register manually:"
		warn "  claude plugin marketplace add $SCRIPT_DIR --scope user"
		warn "  claude plugin install tldraw-claude@sociotechnica --scope user"
		return 0
	fi

	if ! claude plugin install "tldraw-claude@sociotechnica" --scope user 2>/dev/null; then
		warn "Plugin install failed — install manually:"
		warn "  claude plugin install tldraw-claude@sociotechnica --scope user"
		return 0
	fi

	success "Plugin registered with Claude Code"
}

register_plugin || true

echo ""
echo "Setup complete!"
echo ""
echo "To start the canvas:"
echo "  $SCRIPT_DIR/bin/tldraw-claude start"
echo ""
