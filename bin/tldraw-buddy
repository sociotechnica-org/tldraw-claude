#!/usr/bin/env bash
# tldraw-buddy — Start the tldraw canvas and WebSocket relay.
#
# Usage:
#   tldraw-buddy start    Start the widget + WS relay (opens browser)
#   tldraw-buddy stop     Stop background processes
#   tldraw-buddy status   Check if services are running

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
WIDGET_DIR="$PLUGIN_ROOT/widget"
PID_DIR="$PLUGIN_ROOT/.pids"

info() { echo "  → $1"; }
success() { echo "  ✓ $1"; }
error() { echo "  ✗ $1" >&2; }

ensure_deps() {
	if ! command -v bun &>/dev/null; then
		error "Bun is required. Install from https://bun.sh"
		exit 1
	fi

	if [ ! -d "$WIDGET_DIR/node_modules" ]; then
		info "Installing widget dependencies..."
		(cd "$WIDGET_DIR" && bun install)
	fi
}

# Find an available port starting from the given base
find_free_port() {
	local port="$1"
	while lsof -i ":$port" &>/dev/null 2>&1; do
		port=$((port + 1))
	done
	echo "$port"
}

cmd_start() {
	ensure_deps
	mkdir -p "$PID_DIR"

	# Start WS relay
	if [ -f "$PID_DIR/ws-relay.pid" ] && kill -0 "$(cat "$PID_DIR/ws-relay.pid")" 2>/dev/null; then
		local ws_port
		ws_port="$(cat "$PID_DIR/ws-relay.port" 2>/dev/null || echo 4000)"
		info "WS relay already running on port $ws_port (pid $(cat "$PID_DIR/ws-relay.pid"))"
	else
		local ws_port
		ws_port="$(find_free_port 4000)"
		info "Starting WebSocket relay on port $ws_port..."
		TLDRAW_WS_PORT="$ws_port" bun "$WIDGET_DIR/ws-server.ts" >"$PID_DIR/ws-relay.log" 2>&1 &
		echo $! >"$PID_DIR/ws-relay.pid"
		echo "$ws_port" >"$PID_DIR/ws-relay.port"
		success "WS relay started (pid $!, port $ws_port)"
	fi

	# Start Vite dev server
	if [ -f "$PID_DIR/widget.pid" ] && kill -0 "$(cat "$PID_DIR/widget.pid")" 2>/dev/null; then
		local widget_port
		widget_port="$(cat "$PID_DIR/widget.port" 2>/dev/null || echo 5173)"
		info "Widget already running on port $widget_port (pid $(cat "$PID_DIR/widget.pid"))"
	else
		local widget_port
		widget_port="$(find_free_port 5173)"
		info "Starting tldraw widget on port $widget_port..."
		(cd "$WIDGET_DIR" && TLDRAW_WS_PORT="$ws_port" VITE_WS_PORT="$ws_port" bun run dev -- --port "$widget_port") >"$PID_DIR/widget.log" 2>&1 &
		echo $! >"$PID_DIR/widget.pid"
		echo "$widget_port" >"$PID_DIR/widget.port"
		success "Widget started (pid $!, port $widget_port)"
	fi

	echo ""
	echo "tldraw-buddy ready!"
	echo "  Canvas:    http://localhost:$widget_port"
	echo "  WS relay:  ws://localhost:$ws_port"
	echo ""
	echo "Open http://localhost:$widget_port in your browser to see the shared canvas."

	# Try to open browser
	if command -v open &>/dev/null; then
		sleep 2
		open "http://localhost:$widget_port"
	fi
}

cmd_stop() {
	local stopped=false

	for name in ws-relay widget; do
		local pidfile="$PID_DIR/$name.pid"
		if [ -f "$pidfile" ]; then
			local pid
			pid="$(cat "$pidfile")"
			if kill -0 "$pid" 2>/dev/null; then
				kill "$pid" 2>/dev/null || true
				success "Stopped $name (pid $pid)"
				stopped=true
			fi
			rm -f "$pidfile" "$PID_DIR/$name.port"
		fi
	done

	if [ "$stopped" = false ]; then
		info "Nothing running."
	fi
}

cmd_status() {
	for name in ws-relay widget; do
		local pidfile="$PID_DIR/$name.pid"
		local portfile="$PID_DIR/$name.port"
		if [ -f "$pidfile" ] && kill -0 "$(cat "$pidfile")" 2>/dev/null; then
			local port
			port="$(cat "$portfile" 2>/dev/null || echo "?")"
			success "$name running (pid $(cat "$pidfile"), port $port)"
		else
			info "$name not running"
		fi
	done
}

case "${1:-help}" in
start) cmd_start ;;
stop) cmd_stop ;;
status) cmd_status ;;
snapshot | create | update | delete | connect | clear | save | load | help)
	exec bun "$PLUGIN_ROOT/src/cli.ts" "$@"
	;;
*)
	exec bun "$PLUGIN_ROOT/src/cli.ts" "$@"
	;;
esac
